generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum PlanType {
  free
  pro
  enterprise
}

enum UserRole {
  user
  admin
}

enum DeviceStatus {
  online
  offline
}

enum MessageType {
  sent
  received
}

enum MessageStatus {
  pending
  delivered
  failed
}

enum PaymentMethod {
  bkash
  nagad
  rocket
}

enum PaymentStatus {
  pending
  approved
  rejected
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  planType  PlanType  @default(free) @map("plan_type")
  role      UserRole  @default(user)
  isPaid    Boolean   @default(false) @map("is_paid")
  isBanned  Boolean   @default(false) @map("is_banned")
  createdAt DateTime  @default(now()) @map("created_at")
  devices   Device[]
  messages  Message[]
  payments  Payment[]

  @@map("users")
}

model Device {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  userId          String       @map("user_id") @db.ObjectId
  deviceName      String       @map("device_name")
  connectionToken String       @unique @map("connection_token")
  socketId        String?      @map("socket_id")
  status          DeviceStatus @default(offline)
  selectedSim     Int          @default(1) @map("selected_sim")
  createdAt       DateTime     @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("devices")
}

model Message {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  userId      String        @map("user_id") @db.ObjectId
  deviceId    String        @map("device_id") @db.ObjectId
  phoneNumber String        @map("phone_number")
  messageBody String        @map("message_body")
  type        MessageType
  status      MessageStatus @default(pending)
  createdAt   DateTime      @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@map("messages")
}

model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  userId        String        @map("user_id") @db.ObjectId
  senderNumber  String        @map("sender_number")
  trxId         String        @unique @map("trx_id")
  paymentMethod PaymentMethod @map("payment_method")
  amount        Float
  status        PaymentStatus @default(pending)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model Settings {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  singletonKey String   @unique @default("SYSTEM") @map("singleton_key")
  bkashNumber  String?  @map("bkash_number")
  nagadNumber  String?  @map("nagad_number")
  rocketNumber String?  @map("rocket_number")
  appPrice     Float?   @map("app_price")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
